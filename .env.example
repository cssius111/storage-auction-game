# Copy to .env and provide local values. Never commit .env.
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

AI_DECISION_TIMEOUT_SECONDS=8
AI_MAX_NETWORK_RETRIES=1
AI_CIRCUIT_BREAKER_FAILURES=3
AI_MAX_CALLS_PER_UNIT=18

OBSERVATION_DURATION_SECONDS=30
OBSERVATION_MAX_FOCUS_ACTIONS=2

